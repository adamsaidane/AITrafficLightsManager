<routes>
    <!-- Types de véhicules -->
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5" maxSpeed="50"/>

    <!-- Routes possibles -->
    <route id="N_to_W" edges="N_to_C C_to_W"/>
    <route id="N_to_S" edges="N_to_C C_to_S"/>
    <route id="N_to_E" edges="N_to_C C_to_E"/>
    <route id="S_to_E" edges="S_to_C C_to_E"/>
    <route id="S_to_N" edges="S_to_C C_to_N"/>
    <route id="S_to_W" edges="S_to_C C_to_W"/>
    <route id="E_to_N" edges="E_to_C C_to_N"/>
    <route id="E_to_W" edges="E_to_C C_to_W"/>
    <route id="E_to_S" edges="E_to_C C_to_S"/>
    <route id="W_to_S" edges="W_to_C C_to_S"/>
    <route id="W_to_E" edges="W_to_C C_to_E"/>
    <route id="W_to_N" edges="W_to_C C_to_N"/>

    <!--
        FLUX DE TRAFIC — DENSITE 50% (curriculum etape 1)
        Originales : straight=0.08  turns=0.06
        50%        : straight=0.04  turns=0.03
        Corrections:
          - departLane="best"    : SUMO choisit la voie optimale
          - departSpeed="max"    : pas de demarrage lent qui bouche l'entree
          Pour changer density : python patch_traffic.py -rou intersection.rou.xml -density 0.7
    -->

    <!-- NORD -->
    <flow id="flow_N_straight" type="car" begin="0" end="3600" probability="0.06" route="N_to_S" departLane="best"/>
    <flow id="flow_N_right"    type="car" begin="0" end="3600" probability="0.03" route="N_to_W" departLane="best"/>
    <flow id="flow_N_left"     type="car" begin="0" end="3600" probability="0.03" route="N_to_E" departLane="best"/>

    <!-- SUD -->
    <flow id="flow_S_straight" type="car" begin="0" end="3600" probability="0.06" route="S_to_N" departLane="best"/>
    <flow id="flow_S_right"    type="car" begin="0" end="3600" probability="0.03" route="S_to_E" departLane="best"/>
    <flow id="flow_S_left"     type="car" begin="0" end="3600" probability="0.03" route="S_to_W" departLane="best"/>

    <!-- EST -->
    <flow id="flow_E_straight" type="car" begin="0" end="3600" probability="0.06" route="E_to_W" departLane="best"/>
    <flow id="flow_E_right"    type="car" begin="0" end="3600" probability="0.03" route="E_to_N" departLane="best"/>
    <flow id="flow_E_left"     type="car" begin="0" end="3600" probability="0.03" route="E_to_S" departLane="best"/>

    <!-- OUEST -->
    <flow id="flow_W_straight" type="car" begin="0" end="3600" probability="0.06" route="W_to_E" departLane="best"/>
    <flow id="flow_W_right"    type="car" begin="0" end="3600" probability="0.03" route="W_to_S" departLane="best"/>
    <flow id="flow_W_left"     type="car" begin="0" end="3600" probability="0.03" route="W_to_N" departLane="best"/>

</routes>